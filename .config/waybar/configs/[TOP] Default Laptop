// Catppuccin Mocha waybar config for Sway
// Includes JaKooLit module library, overrides for sway compatibility
{
    "include": [
        "$HOME/.config/waybar/Modules",
        "$HOME/.config/waybar/ModulesCustom",
        "$HOME/.config/waybar/ModulesGroups"
    ],

    "layer": "top",
    "position": "top",
    "height": 33,
    "margin-top": 4,
    "margin-left": 6,
    "margin-right": 6,

    "modules-left": [
        "custom/menu",
        "sway/workspaces",
        "sway/window",
        "tray"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "group/mobo_drawer",
        "custom/separator#dot",
        "group/laptop",
        "custom/separator#dot",
        "group/audio",
        "custom/separator#dot",
        "network",
        "custom/bluetooth",
        "custom/separator#dot",
        "idle_inhibitor",
        "custom/swaync"
    ],

    // --- Sway-specific modules ---

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "focused": "â—ڈ",
            "default": "â—‹",
            "urgent": "â—ڈ"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "sway/window": {
        "format": "{}",
        "max-length": 30,
        "tooltip": false,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": " $1",
            "(.*) - fish": "> [$1]",
            "(.*) - zsh": "> [$1]"
        }
    },

    // --- Module overrides for sway (replace hyprctl commands) ---

    "custom/menu": {
        "format": "  ",
        "on-click": "pkill rofi || rofi -show drun -modi run,drun,filebrowser,window",
        "on-click-right": "",
        "on-click-middle": "",
        "tooltip": true,
        "tooltip-format": "App Launcher"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} َ°‚° {volume}%",
        "format-muted": "َ°–پ",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", "َ°•¾", ""]
        },
        "scroll-step": 5.0,
        "on-click": "pamixer --toggle-mute",
        "on-click-right": "pavucontrol -t 3",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "tooltip-format": "{icon} {desc} | {volume}%",
        "smooth-scrolling-threshold": 1
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "on-click": "pamixer --default-source --toggle-mute",
        "on-click-right": "pavucontrol -t 4",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "tooltip-format": "{source_desc} | {source_volume}%",
        "scroll-step": 5
    },

    "backlight": {
        "interval": 2,
        "format": "{icon}",
        "format-icons": [" ", " ", " ", "َ°ƒ‌ ", "َ°ƒ‍ ", "َ°ƒں ", "َ°ƒ  "],
        "tooltip-format": "Backlight {percent}%",
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "smooth-scrolling-threshold": 1
    },

    "battery": {
        "full-at": 100,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": "َ±ک– {capacity}%",
        "format-alt-click": "click",
        "format-full": "{icon} Full",
        "format-alt": "{icon} {time}",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "format-time": "{H}h {M}min",
        "tooltip": true,
        "tooltip-format": "{timeTo} {power}w"
    },

    "memory": {
        "interval": 10,
        "format": "{used:0.1f}G َ°¾†",
        "format-alt": "{percentage}% َ°¾†",
        "format-alt-click": "click",
        "tooltip": true,
        "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
        "on-click-right": ""
    },

    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon}",
        "format-ethernet": "َ°Œک",
        "format-disconnected": "َ°Œ™",
        "tooltip-format": "{ipaddr}  {bandwidthUpBits}  {bandwidthDownBits}",
        "format-linked": "َ°ˆپ {ifname} (No IP)",
        "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname} َ°Œک",
        "tooltip-format-disconnected": "َ°Œ™ Disconnected",
        "max-length": 30,
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "on-click": "kitty --title nmtui nmtui",
        "on-click-right": "nm-connection-editor"
    },

    "custom/bluetooth": {
        "format": "{}",
        "interval": 5,
        "return-type": "json",
        "exec": "if bluetoothctl show | grep -q 'Powered: yes'; then count=$(bluetoothctl devices Connected | wc -l); if [ \"$count\" -gt 0 ]; then printf '{\"text\": \"َ°‚± %s\", \"tooltip\": \"%s\", \"class\": \"connected\"}' \"$count\" \"$(bluetoothctl devices Connected | cut -d' ' -f3- | paste -sd', ')\"; else printf '{\"text\": \" \", \"tooltip\": \"No devices connected\", \"class\": \"on\"}'; fi; else printf '{\"text\": \"َ°‚³\", \"tooltip\": \"Bluetooth off\", \"class\": \"off\"}'; fi",
        "on-click": "kitty --title bluetuith bluetuith",
        "tooltip": true
    },

    "custom/power": {
        "format": " âڈ» ",
        "on-click": "swaynag -t warning -m 'Power Menu' -b 'Logout' 'swaymsg exit' -b 'Reboot' 'systemctl reboot' -b 'Shutdown' 'systemctl poweroff'",
        "on-click-right": "",
        "tooltip": true,
        "tooltip-format": "Power Menu"
    }
}
